import system.lib.path

if ARGC > 0:
    i = 0
    while i < ARGC:
        pair = system.lib.path.split_assignment(argv(i))
        if pair["name"] == "":
            print "env currently only supports NAME=VALUE arguments"
            i = ARGC
        else:
            ENV[pair["name"]] = pair["value"]
            i = i + 1
names = keys(ENV)
i = 0
while i < len(names):
    print names[i] + "=" + str(ENV[names[i]])
    i = i + 1
