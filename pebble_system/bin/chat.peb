import system.lib.ai
import system.lib.path

CHAT_STATE_FILE = ".__chat_session__.txt"

def join_args(args):
    out = ""
    i = 0
    while i < len(args):
        if i > 0:
            out = out + " "
        out = out + args[i]
        i = i + 1
    return out

def split_lines_local(text):
    lines = []
    current = ""
    i = 0
    while i < len(text):
        if text[i] == "\n":
            append(lines, current)
            current = ""
        else:
            current = current + text[i]
        i = i + 1
    if len(text) == 0:
        return []
    append(lines, current)
    return lines

def join_lines_local(lines):
    out = ""
    i = 0
    while i < len(lines):
        if i > 0:
            out = out + "\n"
        out = out + lines[i]
        i = i + 1
    return out

def encode_text(text):
    out = ""
    i = 0
    while i < len(text):
        ch = text[i]
        if ch == "\\":
            out = out + "\\\\"
        elif ch == "\n":
            out = out + "\\n"
        else:
            out = out + ch
        i = i + 1
    return out

def decode_text(text):
    out = ""
    i = 0
    while i < len(text):
        ch = text[i]
        if ch == "\\" and i + 1 < len(text):
            nxt = text[i + 1]
            if nxt == "n":
                out = out + "\n"
                i = i + 2
            elif nxt == "\\":
                out = out + "\\"
                i = i + 2
            else:
                out = out + nxt
                i = i + 2
        else:
            out = out + ch
            i = i + 1
    return out

def configured_base_url():
    return system.lib.path.env_value(ENV, "OPENAI_BASE_URL", "")

def configured_api_key():
    return system.lib.path.env_value(ENV, "OPENAI_API_KEY", "")

def configured_model():
    return system.lib.path.env_value(ENV, "OPENAI_MODEL", system.lib.ai.default_model())

def configured_system_prompt():
    return system.lib.path.env_value(ENV, "OPENAI_SYSTEM_PROMPT", system.lib.ai.default_system_prompt())

def configured_timeout_ms():
    return int(system.lib.path.env_value(ENV, "OPENAI_TIMEOUT_MS", "10000"))

def ensure_config():
    if configured_base_url() == "":
        print "chat: OPENAI_BASE_URL is not set"
        return 0
    if configured_api_key() == "":
        print "chat: OPENAI_API_KEY is not set"
        return 0
    return 1

def load_history():
    if file_exists(CHAT_STATE_FILE) == 0:
        return []
    lines = split_lines_local(read_file(CHAT_STATE_FILE))
    history = []
    i = 0
    while i < len(lines):
        line = lines[i]
        sep = -1
        j = 0
        while j < len(line):
            if line[j] == "|":
                sep = j
                j = len(line)
            else:
                j = j + 1
        if sep > 0:
            role = ""
            content = ""
            j = 0
            while j < sep:
                role = role + line[j]
                j = j + 1
            j = sep + 1
            while j < len(line):
                content = content + line[j]
                j = j + 1
            append(history, {"role": role, "content": decode_text(content)})
        i = i + 1
    return history

def save_history(history):
    lines = []
    i = 0
    while i < len(history):
        append(lines, history[i]["role"] + "|" + encode_text(history[i]["content"]))
        i = i + 1
    write_file(CHAT_STATE_FILE, join_lines_local(lines))

def clear_history():
    if file_exists(CHAT_STATE_FILE):
        delete_file(CHAT_STATE_FILE)

def history_text(history):
    lines = []
    i = 0
    while i < len(history):
        append(lines, history[i]["role"] + "|" + encode_text(history[i]["content"]))
        i = i + 1
    return join_lines_local(lines)

def ask_once(prompt, history):
    print "waiting for model..."
    result = system.lib.ai.chat_complete(configured_base_url(), configured_api_key(), configured_model(), configured_system_prompt(), history_text(history), prompt, configured_timeout_ms())
    if result["ok"] == 0:
        print "chat failed: " + result["error"]
        return {"ok": 0, "history": history}
    if result["insecure_tls"]:
        print "warning: TLS certificate verification failed; using insecure fallback"
    print result["content"]
    out = []
    i = 0
    while i < len(history):
        append(out, history[i])
        i = i + 1
    append(out, {"role": "user", "content": prompt})
    append(out, {"role": "assistant", "content": result["content"]})
    return {"ok": 1, "history": out}

def usage():
    print "usage: chat [PROMPT]"
    print "reads OPENAI_BASE_URL and OPENAI_API_KEY from environment"
    print "optional: OPENAI_MODEL, OPENAI_SYSTEM_PROMPT, OPENAI_TIMEOUT_MS"

def repl():
    history = load_history()
    if len(history) == 0:
        print "Pebble chat"
        print "Type messages. Use 'exit' or 'quit' to leave."
    while 1:
        line = input("chat> ")
        if line == "exit" or line == "quit":
            clear_history()
            return 0
        if line == "":
            continue
        result = ask_once(line, history)
        if result["ok"]:
            history = result["history"]
            save_history(history)

if ensure_config() == 0:
    usage()
elif ARGC == 0:
    repl()
else:
    result = ask_once(join_args(ARGV), [])
    if result["ok"]:
        clear_history()
