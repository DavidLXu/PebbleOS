def path_depth(name):
    count = 0
    i = 0
    while i < len(name):
        if name[i] == "/":
            count = count + 1
        i = i + 1
    return count

def basename(name):
    out = name
    i = len(name) - 1
    while i >= 0:
        if name[i] == "/":
            return slice(name, i + 1, len(name))
        i = i - 1
    return out

def slice(text, start_index, end_index):
    out = ""
    i = start_index
    while i < end_index:
        out = out + text[i]
        i = i + 1
    return out

def indent(depth):
    out = ""
    i = 0
    while i < depth:
        out = out + "  "
        i = i + 1
    return out

def contains(items, target):
    i = 0
    while i < len(items):
        if items[i] == target:
            return 1
        i = i + 1
    return 0

