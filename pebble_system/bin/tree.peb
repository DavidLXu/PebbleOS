                if name[j] == "/":
                    if len(part) > 0:
                        if depth > 0:
                            if contains(printed_dirs, part) == 0:
                                print indent(path_depth(part)) + basename(part) + "/"
                                append(printed_dirs, part)
                    part = part + "/"
                else:
                    part = part + name[j]
                j = j + 1
            if directory_exists(name):
                if contains(printed_dirs, name) == 0:
                    print indent(depth) + basename(name) + "/"
                    append(printed_dirs, name)
            else:
                print indent(depth) + basename(name)
            i = i + 1
